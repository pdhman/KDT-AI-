//@version=6
indicator("다중 타임프레임 MA", overlay=true)

// ============================================================
// 1) 다중 타임프레임 MA (request.security)
// request.security(심볼, 타임프레임, 표현식)
// ============================================================

// 일봉 기준 20일 / 60일 이동평균 (어떤 타임프레임 차트에서든)
dailyMA20 = request.security(syminfo.tickerid, "D", ta.sma(close, 20))
dailyMA60 = request.security(syminfo.tickerid, "D", ta.sma(close, 60))

// 주봉 기준 10주 이동평균
weeklyMA10 = request.security(syminfo.tickerid, "W", ta.sma(close, 10))

plot(dailyMA20, color=color.red, linewidth=2, title="일봉 MA20")
plot(dailyMA60, color=color.blue, linewidth=2, title="일봉 MA60")
plot(weeklyMA10, color=color.purple, linewidth=3, title="주봉 MA10")

// ============================================================
// 2) 현재 차트 타임프레임 기준 기본 SMA
// (현재 보고 있는 차트의 주기를 그대로 사용)
// ============================================================

sma10  = ta.sma(close, 10)
sma20  = ta.sma(close, 20)
sma50  = ta.sma(close, 50)
sma120 = ta.sma(close, 120)
sma240 = ta.sma(close, 240)

plot(sma10,  color=color.orange,  linewidth=1, title="SMA 10")
plot(sma20,  color=color.green,   linewidth=1, title="SMA 20")
plot(sma50,  color=color.aqua,    linewidth=1, title="SMA 50")
plot(sma120, color=color.fuchsia, linewidth=1, title="SMA 120")
plot(sma240, color=color.gray,    linewidth=2, title="SMA 240")
